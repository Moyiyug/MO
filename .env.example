# ============================================================
# MO 后端环境变量示例 (复制为 .env 后填入真实值；.env 不入库)
# 切勿把真实密钥提交到版本控制
# ============================================================

# ---- 应用基础 ----
APP_ENV=dev
API_BASE_URL=http://localhost:8000

# ---- 存储 ----
# MVP 用 SQLite；生产可换其他 DSN
DATABASE_URL=sqlite:///./runtime/mo.db
RUNTIME_DIR=./runtime
# Chroma 向量索引目录（按 task 子目录隔离）
CHROMA_INDEX_DIR=./runtime/indexes

# ---- 模型配置 ----
# 模型 profile 表路径 (provider/model_name/base_url/capabilities)
MODEL_PROFILES_PATH=./apps/api/model_profiles.json
MODEL_CALL_TIMEOUT_SECONDS=60
MODEL_CALL_MAX_RETRIES=2

# ---- 模型 API Key (按 model_profiles.json 里 api_key_env 的命名提供) ----
#   deepseek-v4-pro   — planning / reasoning / report
#   deepseek-v4-flash — summarize / classify
# OpenAI 兼容: https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi / Moonshot: kimi-k2.6（多模态 vision + video，256K context）
# 国内端点: https://api.moonshot.cn/v1 ；国际: https://api.moonshot.ai/v1
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# 可选: OpenAI 兼容端点 (供 paper-qa / gpt-researcher 走自定义 base url)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# ---- 上游能力相关 (按需启用) ----
# 私有仓库 / RepoIngest (gitingest)，仅在需要时提供；日志中必须脱敏
# GITHUB_TOKEN=
# 仓库摄取体积上限（字节，默认 50MB）与排除/包含 glob（逗号分隔）
# REPO_INGEST_MAX_BYTES=50000000
# REPO_INGEST_EXCLUDE_PATTERNS=.git,.env,node_modules,venv,__pycache__,*.pyc,*.bin,*.png,*.jpg
# REPO_INGEST_INCLUDE_PATTERNS=
# gpt-researcher 默认检索器 Tavily (仅在 allow_web_search 时使用)
# TAVILY_API_KEY=

# ---- 权限默认值 (保守) ----
DEFAULT_ALLOW_WEB_SEARCH=false
DEFAULT_ALLOW_REPO_CLONE=true
DEFAULT_ALLOW_SMOKE_TEST=false
DEFAULT_ALLOW_DEPENDENCY_INSTALL=false
