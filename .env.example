# ============================================================
# MO backend environment template
#
# Copy this file to .env at the repository root, then fill in
# local values. Never commit real API keys or tokens.
#
# Recommended backend start command from repository root:
#   uvicorn mo_api.main:app --reload --port 8000 --app-dir apps/api
# ============================================================

# ---- Application ----
APP_ENV=dev
API_BASE_URL=http://localhost:8000

# Frontend origins. Keep the regex in dev so Vite can move from 5173 to 5174.
CORS_ALLOW_ORIGINS=http://localhost:5173
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

# ---- Local storage ----
# Relative paths are resolved from the repository root by mo_api.config.
DATABASE_URL=sqlite:///./runtime/mo.db
RUNTIME_DIR=./runtime
CHECKPOINT_DB_PATH=./runtime/mo_checkpoints.db
EXECUTE_CHECKPOINT_DB_PATH=./runtime/mo_execute_checkpoints.db
CHROMA_INDEX_DIR=./runtime/indexes
PAPER_INDEX_DIR=./runtime/indexes/paper

# ---- Model profiles and gateway ----
# Model names/routes live in this JSON file; code must not hardcode model config.
MODEL_PROFILES_PATH=./apps/api/model_profiles.json
MODEL_CALL_TIMEOUT_SECONDS=30
MODEL_CALL_MAX_RETRIES=2

# DeepSeek: planning, reasoning, reporting, summarize/classify.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi/Moonshot: vision/video-capable profile.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Qwen/DashScope: embedding profile used by paper/retrieval integrations.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com

# Optional OpenAI-compatible variables for upstream libraries that read them.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ---- RepoDiscovery (F-015) ----
# If a task is created without repo URLs, MO can discover public GitHub repos.
REPO_DISCOVERY_ENABLED=true
GITHUB_API_BASE_URL=https://api.github.com
REPO_DISCOVERY_MAX_CANDIDATES=15
REPO_DISCOVERY_PER_QUERY=5
REPO_DISCOVERY_TIMEOUT_SECONDS=15

# Optional: improves GitHub rate limits and enables authorized private access.
GITHUB_TOKEN=

# ---- RepoIngest (gitingest) ----
REPO_INGEST_MAX_BYTES=50000000
REPO_INGEST_EXCLUDE_PATTERNS=.git,.env,node_modules,venv,__pycache__,*.pyc,*.bin,*.png,*.jpg
# Optional include allowlist. Examples: *.md,*.py or docs/**,src/**
REPO_INGEST_INCLUDE_PATTERNS=

# ---- Paper/Web research ----
# Used only when task permissions allow web research.
TAVILY_API_KEY=
WEB_SEARCH_RETRIEVER=
# Some upstream tools read RETRIEVER directly.
# RETRIEVER=tavily

# ---- Conservative task permission defaults ----
DEFAULT_ALLOW_WEB_SEARCH=false
DEFAULT_ALLOW_REPO_CLONE=true
DEFAULT_ALLOW_SMOKE_TEST=false
DEFAULT_ALLOW_DEPENDENCY_INSTALL=false

# ---- DemoMode ----
# true seeds an offline demo task during backend startup.
DEMO_MODE=false

# ---- Sandbox smoke test ----
# Still requires task permission + workflow approval before running.
SANDBOX_ENABLED=false
SANDBOX_COMMAND_WHITELIST=pytest,python -m pytest,python -m pytest .,python --version,pip --version,npm test,node --version,npm --version
SANDBOX_TIMEOUT_SECONDS=120
SANDBOX_WORKDIR_BASE=./runtime/repos
