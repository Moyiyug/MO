# ============================================================
# MO 后端环境变量示例 (复制为 .env 后填入真实值；.env 不入库)
# 切勿把真实密钥提交到版本控制
#
# 启动方式（在仓库根目录执行，不是 apps/api）：
#   uvicorn mo_api.main:app --reload --port 8000 --app-dir apps/api
# ============================================================

# ---- 应用基础 ----
APP_ENV=dev
API_BASE_URL=http://localhost:8000
# 前端开发地址（逗号分隔多个来源）
CORS_ALLOW_ORIGINS=http://localhost:5173
# 开发环境允许本机任意端口（Vite 端口被占用会漂移到 5174 等）；生产环境可置空收紧
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

# ---- 存储 ----
# MVP 用 SQLite；生产可换其他 DSN
DATABASE_URL=sqlite:///./runtime/mo.db
RUNTIME_DIR=./runtime
CHECKPOINT_DB_PATH=./runtime/mo_checkpoints.db
EXECUTE_CHECKPOINT_DB_PATH=./runtime/mo_execute_checkpoints.db
# Chroma 向量索引目录（按 task 子目录隔离）
CHROMA_INDEX_DIR=./runtime/indexes

# ---- 模型配置 ----
# 模型 profile 表路径 (provider/model_name/base_url/capabilities)
MODEL_PROFILES_PATH=./apps/api/model_profiles.json
MODEL_CALL_TIMEOUT_SECONDS=60
MODEL_CALL_MAX_RETRIES=2

# ---- 模型 API Key (按 model_profiles.json 里 api_key_env 的命名提供) ----
#   deepseek-v4-pro   — planning / reasoning / report
#   deepseek-v4-flash — summarize / classify
# OpenAI 兼容: https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi / Moonshot: kimi-k2.6（多模态 vision + video，256K context）
# 国内端点: https://api.moonshot.cn/v1 ；国际: https://api.moonshot.ai/v1
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# 可选: OpenAI 兼容端点 (供 paper-qa / gpt-researcher 走自定义 base url)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# ---- RepoDiscovery (F-015：自动发现热门相关仓库) ----
# 留空 repo_urls 时由 GitHub Search API 自动发现；GITHUB_TOKEN 可选（提升限流额度，匿名 10 次/分）
REPO_DISCOVERY_ENABLED=true
# GITHUB_API_BASE_URL=https://api.github.com
# REPO_DISCOVERY_MAX_CANDIDATES=15
# REPO_DISCOVERY_PER_QUERY=5
# REPO_DISCOVERY_TIMEOUT_SECONDS=15

# ---- 上游能力相关 (按需启用) ----
# 私有仓库 / RepoIngest (gitingest) / RepoDiscovery 限流提额，仅在需要时提供；日志中必须脱敏
# GITHUB_TOKEN=
# 仓库摄取体积上限（字节，默认 50MB）与排除/包含 glob（逗号分隔）
# REPO_INGEST_MAX_BYTES=50000000
# REPO_INGEST_EXCLUDE_PATTERNS=.git,.env,node_modules,venv,__pycache__,*.pyc,*.bin,*.png,*.jpg
# 白名单 glob；写 .md 会自动规范为 *.md（勿用纯扩展名以外的复杂规则）
# 白名单 glob；写 .md 会自动规范为 *.md
# REPO_INGEST_INCLUDE_PATTERNS=
# gpt-researcher 默认检索器 Tavily (仅在 allow_web_search 时使用)
# TAVILY_API_KEY=

# ---- M9 PaperResearch / Reproducibility ----
# paper-qa 索引目录（每 task 子目录隔离）
PAPER_INDEX_DIR=./runtime/indexes/paper
# gpt-researcher 检索器（tavily / serpapi / google；需 allow_web_search=true + TAVILY_API_KEY 等）
# WEB_SEARCH_RETRIEVER=tavily
# gpt-researcher 实际读取的 env 名是 RETRIEVER；load_dotenv() 后 .env 中设置即可生效
# RETRIEVER=tavily

# ---- 权限默认值 (保守) ----
DEFAULT_ALLOW_WEB_SEARCH=false
DEFAULT_ALLOW_REPO_CLONE=true
DEFAULT_ALLOW_SMOKE_TEST=false
DEFAULT_ALLOW_DEPENDENCY_INSTALL=false

# ---- M10 DemoMode / Sandbox ----
# 启动时自动种子离线 demo 任务
DEMO_MODE=false
# 沙箱 smoke test（默认关；需 allow_smoke_test + interrupt 审批）
SANDBOX_ENABLED=false
SANDBOX_COMMAND_WHITELIST=pytest,python -m pytest,python --version,pip --version
SANDBOX_TIMEOUT_SECONDS=120
SANDBOX_WORKDIR_BASE=./runtime/repos
